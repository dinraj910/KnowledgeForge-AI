APP_NAME=KnowledgeForge AI API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173

# Ingestion pipeline
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20
DB_PATH=./ingestion.db

# Database / Supabase (for future auth/metadata phases)
DATABASE_URL=postgresql://user:password@localhost:5432/personal_knowledge_ai
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
